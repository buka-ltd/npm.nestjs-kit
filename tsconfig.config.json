{
  "compilerOptions": {
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "noImplicitAny": false,
    "noEmitOnError": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "module": "nodenext",
    "target": "esnext",
    "types": ["node"]
  },
  "include": [".*.ts", "*.config.ts", "*.config.cts"]
}
