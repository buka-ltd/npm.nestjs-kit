{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "command": "pnpm dev",
      "isBackground": true,
      "problemMatcher": ["$tsup-watch", "$tsup-dts-watch"],
      "label": "tsup:watch",
      "detail": "tsup --watch",
      "group": "build",
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      },
      "runOptions": {
        "instanceLimit": 1
      }
    },
    {
      "type": "shell",
      "command": "pnpm build",
      "problemMatcher": ["$tsup", "$tsup-dts"],
      "label": "tsup:build",
      "detail": "tsup --build",
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
